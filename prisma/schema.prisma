generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  name             String
  shortDescription String
  description      String
  imageUrl         String
  price            Float
  specs            Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
